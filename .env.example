# Copy this file to .env for local development (the bot loads it automatically).
# On Railway, do NOT upload a .env file — instead set each of these as a
# "Variable" in your Railway project dashboard. See README.md for details.

# --- Required ---

# From @BotFather on Telegram (/newbot)
BOT_TOKEN=123456789:ABC-your-bot-token-here

# Your numeric Telegram user ID(s), from @userinfobot. Comma-separated for multiple admins.
ADMIN_IDS=123456789

# --- Channels shared via /link ---
# JSON object: button label -> negative numeric chat_id.
# Get the chat_id by forwarding a message from the channel to @JsonDumpBot.
# The bot must be an admin of each channel with "Invite Users via Link" enabled.
CHANNELS_JSON={"📢 Main Channel": -1001234567890, "💬 Discussion Group": -1009876543210}

# How long (seconds) each generated invite link stays valid. Default: 3600 (1 hour).
LINK_EXPIRY_SECONDS=3600

# Direct image URL (or local file path) shown on /start.
WELCOME_PHOTO=https://i.imgur.com/your-welcome-image.jpg

# Where the SQLite database file lives. On Railway, point this inside a
# mounted Volume (e.g. /data/bot_database.db) so it survives redeploys.
DATABASE_PATH=bot_database.db

# --- AI assistant (auto-replies while admin is /offline) ---

AI_ENABLED=true

# "openai_compatible" (Groq / ChatGPT / Gemini) or "anthropic" (Claude)
AI_PROVIDER=openai_compatible

# Used only if AI_PROVIDER=anthropic. From https://console.anthropic.com
ANTHROPIC_API_KEY=PUT_YOUR_ANTHROPIC_API_KEY_HERE
AI_MODEL=claude-sonnet-4-6

# Used only if AI_PROVIDER=openai_compatible. Default preset below is Groq (free).
#   ChatGPT:  OPENAI_BASE_URL=https://api.openai.com/v1        OPENAI_MODEL=gpt-4.1-mini
#   Gemini:   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/   OPENAI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=PUT_YOUR_GROQ_API_KEY_HERE
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Instructions given to the AI. Edit to match your community's tone/topics.
AI_SYSTEM_PROMPT=You are a friendly, professional support assistant for our Telegram channel. Answer the user's question concisely and politely, in a few sentences. If you don't know something specific to this community (exact rules, prices, schedules, etc.), say you're not sure and that a human admin will follow up soon — never make up specifics you don't actually know.

# How many previous user/assistant exchanges the AI remembers per user.
AI_MAX_HISTORY_TURNS=6
